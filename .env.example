# Public app origin used for canonical URLs, social metadata, sitemap,
# robots.txt, Lighthouse targets, and deployment smoke tests.
#
# Initial Cloudflare Pages rollout:
VITE_PUBLIC_APP_ORIGIN=https://comapeo-cloud-app.pages.dev
#
# Switch to this after the custom domain is active:
# VITE_PUBLIC_APP_ORIGIN=https://app.comapeo.cloud

# Optional error tracking. Leave empty to disable client-side reporting.
VITE_SENTRY_DSN=

# Optional release identifier used by error tracking.
# CI should set this from the full Git SHA.
VITE_APP_RELEASE=

# Deployment environment tag (production | staging | preview).
# Wired by CI per workflow ref; used by Sentry to group events.
VITE_APP_ENV=

# Cloudflare Pages deployment settings.
# Set these as GitHub Actions secrets/variables, not in committed .env files.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Smoke test target used to verify the /api proxy can successfully reach a
# known comapeo-cloud archive server in preview and production deployments.
SMOKE_TEST_ARCHIVE_ORIGIN=

# Sentry source map upload settings.
# Required only if VITE_SENTRY_DSN is set for deployed builds.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
